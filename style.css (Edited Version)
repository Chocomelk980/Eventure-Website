/* RESET */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }


/* VARIABLES */
:root {
  --bg:      #23395d;
  --fg:      #000000;
  --border:  #152238;
  --muted:   #6b7280;
  --primary: #eef0fb;
  --card:    #ffffff;
  --light:   #eef0fb;
  --wide:    960px;
}


/* BASE  */
html { scroll-behavior: smooth; }
body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--fg); font-size: 15px; line-height: 1.6; }
img { display: block; 
    width: 100%; height: 100%; object-fit: cover; }
section { border-bottom: 1px solid var(--border); }


/* IMAGE BOXES — shared style used in hero, about, preview, and carousel */
.hero-img-wrap,
.about-img,
.preview-large,
.preview-small,
.carousel-img-frame {
  border: 1px solid var(--border);
  overflow: hidden;
  background: var(--light);
}
.hero-label{
    color: #ffffff;
}
/* NAV */
/* changed the nav and add img for logo(palitan kung meron nang logo)*/

nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  background: var(--bg);
  padding: 0 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 1000;
  box-shadow: 0.5rem 1rem rgba(0,0,0,.1); 
  border-bottom: 1px solid var(--border);
}

.nav-inner {
 display: flex;
 justify-content: space-between;
 align-items: center;
 background-color: var(--border);
 width: 200%;
 max-width: 1200px;
 margin: auto;
 padding: 0 100px;
 border-radius: 6px;
}
 
.nav-logo {
 color: var(--card);
 font-size: 1.5rem;
 font-weight: bold;
}

.nav-links { 
    display: flex; 
    align-items: center; 
    gap: 28px; }

.nav-logo-img {
  height: 100px;  
  width: 100px;
  display: block;
}

.nav-links {
display: flex;
align-items: center;
gap: 28px;
}

/* Nav link text — same style for both links and dropdown label */
.nav-links a,
.nav-dropdown-label {
  font-size: 13px;
  font-weight: 600;
  color: #ffffff;
  text-decoration: none;
  letter-spacing: 0.04em;
  gap: 10px
;
  transition: 0.3s;
}


.nav-links a:hover,
.nav-dropdown:hover .nav-dropdown-label { 
    color: var(--primary); }


/* Dropdown menu */
.nav-dropdown { 
    position: relative; 
    display: flex; 
    align-items: center; }
.nav-dropdown-label { 
    cursor: default; 
    display: flex; 
    align-items: center; 
    gap: 4px; 
    padding: 16px 0; }
.nav-dropdown:hover .nav-dropdown-label svg 
{ transform: rotate(180deg); }


.nav-dropdown-menu {
  display: none;
  position: absolute;
  right: 0; top: 100%;
  background: var(--card);
  border: 1px solid var(--border);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  min-width: 200px;
}


.nav-dropdown:hover .nav-dropdown-menu { display: block; }


.nav-dropdown-menu a {
  display: block;
  padding: 10px 16px;
  font-size: 13px;
  color: var(--fg);
  text-decoration: none;
}


.nav-dropdown-menu a:hover { background: var(--light); color: var(--bg); }


/* SHARED LAYOUT */
