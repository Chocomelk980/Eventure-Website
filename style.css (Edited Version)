/* RESET */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }




/* VARIABLES */
:root {
  --bg:      #23395d;
  --fg:      #000000;
  --border:  #152238;
  --muted:   #6b7280;
  --primary: #eef0fb;
  --card:    #ffffff;
  --light:   #eef0fb;
  --wide:    960px;
}




/* BASE  */
html { scroll-behavior: smooth; }
body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--fg); font-size: 15px; line-height: 1.6; }
img { display: block;
    width: 100%; height: 100%; object-fit: cover; }
section { border-bottom: 1px solid var(--border); }




/* IMAGE BOXES — shared style used in hero, about, preview, and carousel */
.hero-img-wrap,
.about-img,
.preview-large,
.preview-small,
.carousel-img-frame {
  border: 1px solid var(--border);
  overflow: hidden;
  background: var(--light);
}
.hero-label{
    color: #ffffff;
}
/* NAV */
/* changed the nav and add img for logo(palitan kung meron nang logo)*/


nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  background: var(--bg);
  padding: 0 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 1000;
  box-shadow: 0.5rem 1rem rgba(0,0,0,.1);
  border-bottom: 1px solid var(--border);
}


.nav-inner {
 display: flex;
 justify-content: space-between;
 align-items: center;
 background-color: var(--border);
 width: 200%;
 max-width: 1200px;
 margin: auto;
 padding: 0 100px;
 border-radius: 6px;
}


.nav-logo {
 color: var(--card);
 font-size: 1.5rem;
 font-weight: bold;
}


.nav-links {
    display: flex;
    align-items: center;
    gap: 28px; }


.nav-logo-img {
  height: 100px;  
  width: 100px;
  display: block;
}


.nav-links {
display: flex;
align-items: center;
gap: 28px;
}


/* Nav link text — same style for both links and dropdown label */
.nav-links a,
.nav-dropdown-label {
  font-size: 13px;
  font-weight: 600;
  color: #ffffff;
  text-decoration: none;
  letter-spacing: 0.04em;
  gap: 10px
;
  transition: 0.3s;
}




.nav-links a:hover,
.nav-dropdown:hover .nav-dropdown-label {
    color: var(--primary); }




/* Dropdown menu */
.nav-dropdown {
    position: relative;
    display: flex;
    align-items: center; }
.nav-dropdown-label {
    cursor: default;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 16px 0; }
.nav-dropdown:hover .nav-dropdown-label svg
{ transform: rotate(180deg); }




.nav-dropdown-menu {
  display: none;
  position: absolute;
  right: 0; top: 100%;
  background: var(--card);
  border: 1px solid var(--border);
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
  min-width: 200px;
}




.nav-dropdown:hover .nav-dropdown-menu { display: block; }




.nav-dropdown-menu a {
  display: block;
  padding: 10px 16px;
  font-size: 13px;
  color: var(--fg);
  text-decoration: none;
}




.nav-dropdown-menu a:hover { background: var(--light); color: var(--bg); }




/* SHARED LAYOUT */
#home{
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    padding-top: 20px;
    border: 2px solid white;
    border-radius: 15px;
    background: rgba(0,0,0,.3);
    backdrop-filter: blur(10px);
    margin: 20px;


}
section{
    padding: 40px 0;    
}


.section-inner {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 64px 32px; }


.hero-title{
    width: 300px;
    height: 100px;


}


.hero-grid{
    display: block;
    min-height: auto;
    padding-top: 0;
}


.hero-text{
  color: var(--primary);
  text-align: left;
}


.hero-label { font-size: 16px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
.hero-text { color: var(--light); margin-bottom: 12px; }
.hero-img-wrap { aspect-ratio: 4/3; }






.btn {
  display: inline-block;
  margin-top: 24px;
  padding: 10px 28px;
  border: 1px solid var(--border);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--fg);
  text-decoration: none;
  background: var(--card);
  transition: all 0.3s ease;
}


.hero-buttons{
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-top: 20px;
}


.btn:hover{
  transform: translateY(-10px);
  box-shadow: 0 10px 25px rgba(0,0,0,.3);
  background: var(--card);
  color: var(--fg);
}


/* TUTORIAL CAROUSEL */
#tutorial { background: var(--card);}


/* Hide the radio inputs — they only control which slide is visible */
input[name="slide"] { display: none; }




/* All slides and descriptions are hidden by default */
.slide { display: none;  transition: 0.3s ease;}
.slide-desc { display: none; text-align: center; color: var(--border); max-width: 680px; margin: 20px auto 0; }


/* Show the slide that matches the checked radio input */
#s1:checked ~ .carousel-wrap .slide-1,
#s2:checked ~ .carousel-wrap .slide-2,
#s3:checked ~ .carousel-wrap .slide-3,
#s4:checked ~ .carousel-wrap .slide-4 { display: flex; align-items: center; gap: 12px; }




/* Show the description that matches the checked radio input */
#s1:checked ~ .slide-desc.desc-1,
#s2:checked ~ .slide-desc.desc-2,
#s3:checked ~ .slide-desc.desc-3,
#s4:checked ~ .slide-desc.desc-4 { display: block; }


/* Highlight the dot that matches the checked radio input */
#s1:checked ~ .carousel-dots label:nth-child(1),
#s2:checked ~ .carousel-dots label:nth-child(2),
#s3:checked ~ .carousel-dots label:nth-child(3),
#s4:checked ~ .carousel-dots label:nth-child(4) { background: var(--primary); }


.carousel-img-frame { flex: 1; aspect-ratio: 16/9; }


.carousel-btn {
  flex-shrink: 0;
  width: 40px; height: 40px;
  border: 1px solid var(--border);
  background: var(--card);
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--fg);
  text-decoration: none;
  font-family: monospace;
  user-select: none;
}


.carousel-btn:hover { background: var(--primary); color: white; border-color: var(--primary); }




.carousel-dots { display: flex; justify-content: center; gap: 8px; margin-top: 14px; }


.carousel-dots label {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--bg);
  cursor: pointer;
  display: block;
}


.carousel-dots label:hover { background: var(--bg); }


/* FEATURES */


.section-feature{
    padding: 60px 20px;
}


.feature-title{
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--card);
}


.feature-inner{
  align-items: center;
  text-align: center;
 
}


.feature-grid{
   display: grid;
   gap: 20px;
   padding: 20px;
   margin: 0 40px;
   grid-template-columns: repeat(3, 1fr);


}


.feature-card{
    background: var(--card);
    padding: 20px;
    border-radius: 12px;
    border: 2px var(--fg);
    text-align: center;
    transition: all 0.3s ease;
}


.feature-card:hover{
  transform: translateY(-10px);
  box-shadow: 0 10px 25px rgba(0,0,0,.3);
  background: var(--card);
  color: var(--fg);
}


.feature-text{
    font-size: 14px;
    line-height: 1.5;
}


.feature-card:hover
.feature-title:hover {
    color: var(--fg);
}




/* ABOUT */
#about { background: var(--card); }


.about-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
  padding: 56px 32px;
  max-width: var(--wide);
  margin: 0 auto;
}


.about-row + .about-row { border-top: 1px solid var(--border); }
.about-img { aspect-ratio: 4/3; }
.about-text h2 { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; margin-bottom: 16px; }
.about-text p { color: var(--muted); margin-bottom: 10px; }


/* REVIEWS */
.reviews {
  padding: 60px 20px;
  text-align: center;
}


.section-reviews {
  font-size: 24px;
  margin-bottom: 30px;
}


.review-container {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap; /* responsive */
}


.review-card {
  background: var(--card);
  padding: 20px;
  border-radius: 12px;
  max-width: 300px;
  border: 1px solid var(--border);
  transition: 0.3s;
}


.review-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.3);
}


.review-text {
  font-size: 14px;
  margin-bottom: 10px;
}


.review-name {
  font-size: 12px;
  opacity: 0.7;
}


/* TEAM */
#team { background: var(--bg);  }


.section-title{
  font-family: 'Playfair Display', serif;
  font-size: 26px;
  font-weight: 700;
  text-align: center;
  margin-bottom: 40px;
  color:var(--card);
}


.team-row { display: flex; justify-content: center; gap: 48px; flex-wrap: wrap; margin-bottom: 32px; }
.team-row:last-of-type { margin-bottom: 0; }


.team-card {
  display: flex; flex-direction: column; align-items: center; text-align: center; width: 160px; gap: 8px;
  box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.1);
  border-radius: 0.5rem;
  border: 0.4rem solid rgba(0,0,0,.1);
  background: var(--card);
  background-color: #ffffff;
  color: #1a1f36;
  border-radius: 12px;
  transition: all 0.3s ease;
}


.team-card:hover{
  transform: translateY(-10px);
  box-shadow: 0 10px 25px rgba(0,0,0,.3);
  background: var(--card);
  color: var(--fg);
}


.team-avatar {
  width: 88px; height: 88px;
  border-radius: 50%;
  border: 2px solid var(--border);
  background: var(--light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--fg);
  overflow: hidden;
}


/* added team-row a */
.team-name { font-weight: 700; font-size: 14px; }
.team-role { font-size: 12px; font-weight: 600; color: var(--fg); }
.team-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }
.team-note { text-align: center; font-size: 12px; color: var(--light); margin-top: 32px; }
.team-row a{ text-decoration: none; font-size: 16px ; color: var(--fg); box-sizing: border-box; justify-content: center;
}
.team-row a:hover { background: var(--light); color: var(--bg); }


/* FOOTER */
footer { background: var(--card); border-top: 1px solid var(--border); padding: 28px 32px; }




.footer-inner {
  max-width: var(--wide);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}


.footer-logo { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700; color: var(--fg); }
.footer-copy { font-size: 12px; color: var(--muted); text-align: right; }


/* TABLET */
@media (max-width: 768px) {
  .feature-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}


/* PHONE */
@media (max-width: 480px) {
  .feature-grid {
    grid-template-columns: 1fr;
  }
}



