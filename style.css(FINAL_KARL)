  backdrop-filter: blur(18px);
  animation: fade-up 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.footer-inner::before {
  content: "";
  position: absolute;
  left: 12%;
  right: 12%;
  top: -14px;
  height: 40px;
  border-radius: 999px;
  background: radial-gradient(circle at 50% 50%, rgba(122, 141, 255, 0.18), transparent 70%);
  filter: blur(16px);
  pointer-events: none;
}

.feature-card:nth-child(2),
.review-card:nth-child(2),
.team-row .team-card:nth-child(2) {
  animation-delay: 0.08s;
}

.feature-card:nth-child(3),
.review-card:nth-child(3),
.team-row .team-card:nth-child(3) {
  animation-delay: 0.16s;
}

.feature-card:nth-child(4),
.team-row:last-of-type .team-card:nth-child(1) {
  animation-delay: 0.24s;
}

.feature-card:nth-child(5),
.team-row:last-of-type .team-card:nth-child(2) {
  animation-delay: 0.32s;
}

.feature-card:nth-child(6) {
  animation-delay: 0.4s;
}

@keyframes fade-up {
  from {
    opacity: 0;
    transform: translateY(24px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes hero-float {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-10px);
  }
}

@keyframes float-glow {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }

  50% {
    transform: translate3d(18px, -16px, 0) scale(1.08);
  }
}

@keyframes sheen {
  0% {
    transform: translateX(-180%) skewX(-22deg);
  }

  100% {
    transform: translateX(420%) skewX(-22deg);
  }
}

.footer-logo {
  font-family: "Sora", sans-serif;
  font-size: 1.2rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #ffffff;
}

.footer-copy {
  color: var(--text-inverse-soft);
  text-align: right;
  font-size: 0.9rem;
}

a:focus-visible,
button:focus-visible,
label:focus-visible {
  outline: 3px solid rgba(130, 221, 255, 0.55);
  outline-offset: 3px;
}

@media (max-width: 1100px) {
  .feature-grid,
  .review-container,
  .team-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-card:nth-child(1),
  .feature-card:nth-child(4) {
    grid-column: span 2;
  }

  .team-row:last-of-type {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: none;
  }
}

@media (max-width: 900px) {
  nav {
    top: 12px;
    padding: 0 12px;
  }

  .nav-inner {
    flex-wrap: wrap;
    justify-content: center;
    padding: 14px 16px;
    border-radius: 28px;
  }

  .nav-brand {
    width: 100%;
    justify-content: center;
  }

  .nav-links {
    justify-content: center;
  }

  #home {
    padding-top: 170px;
  }

  .slide {
    min-height: 0;
    gap: 22px;
  }

  .carousel-img-frame {
    min-height: clamp(320px, 62vw, 440px);
  }

  .tutorial-copy {
    position: static;
    width: 100%;
    padding: 22px 0 0;
    border: 0;
    border-radius: 0;
    background: none;
    box-shadow: none;
    backdrop-filter: none;
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .tutorial-copy::before {
    content: none;
  }

  .slide-desc {
    padding-top: 22px;
    border-top: 1px solid rgba(130, 221, 255, 0.12);
    font-size: 0.98rem;
    line-height: 1.9;
  }

  .carousel-media::after {
    background: linear-gradient(180deg, transparent 46%, rgba(3, 8, 15, 0.1) 68%, rgba(3, 8, 15, 0.34) 100%);
  }

  .tutorial-copy,
  .slide:hover .tutorial-copy,
  .slide:focus-within .tutorial-copy {
    opacity: 1;
    transform: none;
  }

  .about-row,
  .about-row:nth-child(even) {
    grid-template-columns: 1fr;
    gap: 24px;
  }
}

@media (hover: none) {
  .slide {
    min-height: 0;
    gap: 22px;
  }

  .carousel-img-frame {
    min-height: clamp(320px, 62vw, 440px);
  }

  .tutorial-copy {
    position: static;
    width: 100%;
    padding: 22px 0 0;
    border: 0;
    border-radius: 0;
    background: none;
    box-shadow: none;
    backdrop-filter: none;
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .tutorial-copy::before {
    content: none;
  }

  .slide-desc {
    padding-top: 22px;
    border-top: 1px solid rgba(130, 221, 255, 0.12);
    font-size: 0.98rem;
    line-height: 1.9;
  }

  .carousel-media::after {
    background: linear-gradient(180deg, transparent 46%, rgba(3, 8, 15, 0.1) 68%, rgba(3, 8, 15, 0.34) 100%);
  }
}

@media (max-width: 720px) {
  section {
    padding: 72px 0;
  }

  .section-inner,
  .footer-inner {
    width: min(var(--container), calc(100% - 24px));
  }

  #tutorial .section-inner {
    width: min(1280px, calc(100% - 24px));
  }

  .hero-buttons {
    flex-direction: column;
    width: 100%;
  }

  .btn {
    width: 100%;
  }

  .carousel-btn {
    width: 46px;
    height: 46px;
  }

  .carousel-btn-prev {
    left: -24px;
  }

  .carousel-btn-next {
    right: -24px;
  }

  .tutorial-shell {
    padding: 22px;
  }

  .slide {
    width: 100%;
    gap: 20px;
  }

  .tutorial-copy {
    padding-top: 18px;
  }

  .carousel-dots {
    gap: 8px;
    padding: 9px 12px;
  }

  .feature-grid,
  .review-container,
  .team-row,
  .team-row:last-of-type,
  .benefits-list,
  .problems-solutions {
    grid-template-columns: 1fr;
  }

  .feature-card:nth-child(1),
  .feature-card:nth-child(4) {
    grid-column: auto;
  }

  .team-row {
    margin-bottom: 18px;
  }
}

@media (max-width: 580px) {
  .nav-links,
  .nav-dropdown {
    width: 100%;
  }

  .nav-links > a,
  .nav-dropdown-label {
    width: 100%;
  }

  .nav-dropdown-menu {
    display: none;
    position: static;
    width: 100%;
    margin-top: 8px;
    opacity: 0;
    pointer-events: none;
    transform: none;
    box-shadow: none;
  }

  .nav-dropdown.is-open .nav-dropdown-menu,
  .nav-dropdown:focus-within .nav-dropdown-menu {
    display: grid;
    opacity: 1;
    pointer-events: auto;
  }

  .tutorial-shell {
    padding: 18px;
  }

  .slide {
    gap: 20px;
  }

  .carousel-img-frame {
    min-height: clamp(260px, 72vw, 360px);
  }

  .carousel-counter {
    padding: 7px 10px;
    font-size: 0.72rem;
  }

  .carousel-btn {
    width: 40px;
    height: 40px;
    font-size: 1rem;
  }

  .carousel-btn-prev {
    left: -14px;
  }

  .carousel-btn-next {
    right: -14px;
  }

  .carousel-dots {
    padding: 8px 11px;
  }

  .carousel-dots label {
    width: 10px;
    height: 10px;
  }

  .footer-inner {
    flex-direction: column;
    align-items: flex-start;
  }

  .footer-copy {
    text-align: left;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation: none !important;
    transition: none !important;
  }

  html {
    scroll-behavior: auto;
  }
}
